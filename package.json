{
  "name": "stratos",
  "version": "1.0.0",
  "private": true,
  "main": "electron-main.js",
  "description": "Stratos – Elevate Your Language Skills",
  "author": "",
  "productName": "Stratos",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron .",
    "start:desktop": "electron ./app",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& ./.venv/Scripts/python.exe -m PyInstaller --onefile --noconsole --name stratos-backend --icon backend/stratos.ico --distpath backend/bin --workpath build-temp --noconfirm --clean backend/run_server.py\"",
    "build": "npm run build:frontend && npm run build:backend",
    "dist": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "wait-on": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.stratos.app",
    "productName": "Stratos",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "backend/",
      "!backend/__pycache__/**",
      "!backend/*.log",
      "node_modules/",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/build",
        "to": "frontend/build"
      },
      {
        "from": "backend/stratos.ico",
        "to": "stratos.ico"
      },
      {
        "from": "backend/bin/stratos-backend.exe",
        "to": "stratos-backend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "backend/stratos.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stratos",
      "installerIcon": "backend/stratos.ico",
      "uninstallerIcon": "backend/stratos.ico",
      "installerHeaderIcon": "backend/stratos.ico"
    }
  }
}